{
  "servers": {
    "airis-mcp-gateway": {
      "type": "sse",
      "url": "AIRIS_GATEWAY_URL"
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-server-playwright@latest"]
    },
    "magic": {
      "command": "npx",
      "args": ["-y", "@21st-dev/magic-mcp@latest"]
    },
    "morphllm": {
      "command": "npx",
      "args": ["-y", "@morph-llm/morph-mcp@latest"],
      "env": {
        "MORPH_API_KEY": "",
        "ENABLED_TOOLS": "edit_file,warpgrep_codebase_search"
      }
    }
  }
}
